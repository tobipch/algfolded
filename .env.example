# Hostpoint MariaDB (Datenbanken -> MySQL in the Hostpoint control panel).
# Enable remote access ("Externer Zugriff") for the database user so the
# Vercel functions can reach it.
MYSQL_HOST=your-server.hostpoint.internal
MYSQL_USER=your_db_user
MYSQL_PASSWORD=
MYSQL_DATABASE=algfolded
# MYSQL_PORT=3306

# WCA OAuth application (https://www.worldcubeassociation.org/oauth/applications)
# Scope: public. Redirect URI must match WCA_REDIRECT_URI below.
WCA_CLIENT_ID=
WCA_CLIENT_SECRET=
# Production: https://<your-domain>/api/auth/wca/callback
# Local dev (vercel dev): http://localhost:3000/api/auth/wca/callback
WCA_REDIRECT_URI=
